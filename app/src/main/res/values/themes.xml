<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Caogenda" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_purple_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_purple_dark</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary_purple</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_purple_dark</item>

        <!-- UI Elements -->
        <item name="android:windowBackground">@color/gray_surface</item>
    </style>

    <style name="Theme.Caogenda" parent="Base.Theme.Caogenda" />

    <!-- Custom Button Styles -->
    <style name="PetHealth.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PetHealth.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:background">@drawable/bg_button_secondary_new</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textColor">@color/primary_purple</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/primary_purple</item>
        <item name="strokeWidth">2dp</item>
    </style>
</resources>